<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MoonAI Profiler Report</title>
  <style>
    :root {
      --bg: #ffffff;
      --ink: #1a1a1a;
      --muted: #555555;
      --rule: #000000;
      --rule-light: #cccccc;
      --link: #1a0dab;
      --accent: #1d4ed8;
      --caption: #444444;
      --zebra: #f7f7f7;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Source Sans 3", "Source Sans Pro", Calibri, "Helvetica Neue", Arial, sans-serif;
      font-size: 11pt;
      line-height: 1.6;
      color: var(--ink);
      background: var(--bg);
      max-width: 52em;
      margin: 0 auto;
      padding: 2em 1.5em 4em;
    }

    /* Title block */
    .title-block {
      text-align: center;
      margin-bottom: 1.5em;
    }
    .title-block h1 {
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.3em;
    }
    .title-block .subtitle {
      font-size: 0.95rem;
      color: var(--muted);
      margin-bottom: 0.2em;
    }
    .title-block .date {
      font-size: 0.88rem;
      color: var(--muted);
    }
    .title-rule {
      border: none;
      border-top: 2.5px solid var(--accent);
      margin: 1.5em 0;
    }

    /* Abstract */
    .abstract {
      margin-bottom: 2em;
    }
    .abstract h2 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5em;
    }
    .abstract p {
      color: var(--muted);
      text-align: justify;
    }

    /* TOC */
    .toc {
      margin-bottom: 2.5em;
      padding: 1em 1.5em;
      border: 1px solid var(--rule-light);
      background: #fafafa;
    }
    .toc strong {
      display: block;
      margin-bottom: 0.5em;
      font-size: 0.95rem;
    }
    .toc ul {
      list-style: none;
      padding-left: 0;
    }
    .toc li {
      margin: 0.25em 0;
      font-size: 0.9rem;
    }
    .toc li ul {
      padding-left: 1.2em;
    }
    .toc a {
      color: var(--link);
      text-decoration: none;
    }
    .toc a:hover {
      text-decoration: underline;
    }

    /* Sections */
    section {
      margin-bottom: 2.5em;
    }
    h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.6em;
      padding-bottom: 0.3em;
      border-bottom: 1px solid var(--rule-light);
    }
    h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.4em;
      margin-top: 1em;
    }
    p {
      margin-bottom: 0.8em;
    }
    .muted {
      color: var(--muted);
      font-size: 0.9rem;
    }

    /* Booktabs tables */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1em 0;
      font-size: 0.88rem;
    }
    caption {
      text-align: left;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 0.4em;
      color: var(--ink);
    }
    thead {
      border-top: 2px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    tbody {
      border-bottom: 2px solid var(--rule);
    }
    th {
      font-weight: 600;
      padding: 6px 10px;
      text-align: left;
      background: none;
      color: var(--ink);
      white-space: nowrap;
    }
    td {
      padding: 5px 10px;
      vertical-align: top;
    }
    tbody tr:nth-child(even) {
      background: var(--zebra);
    }

    /* Figures */
    .figure-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5em;
      margin: 1em 0;
    }
    figure {
      margin: 1.2em 0;
      padding: 0;
      border: none;
      background: none;
      text-align: center;
    }
    figure img {
      max-width: 100%;
      height: auto;
      border: 1px solid #e0e0e0;
    }
    figcaption {
      margin-top: 0.4em;
      font-size: 0.85rem;
      color: var(--caption);
      text-align: center;
    }

    /* Details / collapsibles */
    details {
      border: none;
      border-top: 1px solid var(--rule-light);
      background: none;
      margin: 1.5em 0;
    }
    summary {
      cursor: pointer;
      list-style: none;
      padding: 0.6em 0;
      font-weight: 700;
      font-size: 1.05rem;
      background: none;
    }
    summary::-webkit-details-marker { display: none; }
    summary::before {
      content: "\25B6\00a0";
      font-size: 0.7em;
      vertical-align: middle;
    }
    details[open] > summary::before {
      content: "\25BC\00a0";
    }
    .details-body {
      padding: 0.5em 0 1em;
    }
    .run-meta {
      font-size: 0.88rem;
      color: var(--muted);
      margin-bottom: 1em;
    }
    .run-meta em {
      font-style: normal;
      font-weight: 600;
      color: var(--ink);
    }

    /* Empty state */
    .empty {
      padding: 1em;
      border: 1px dashed var(--rule-light);
      color: var(--muted);
      font-size: 0.9rem;
    }

    /* Notes */
    .note {
      padding: 0.8em 1em;
      border-left: 3px solid var(--rule-light);
      color: var(--muted);
      font-size: 0.88rem;
      margin-bottom: 1em;
    }

    /* Links */
    a { color: var(--link); }

    /* Print */
    @media print {
      body {
        font-size: 10pt;
        padding: 0;
        max-width: none;
      }
      .toc { page-break-after: always; }
      section { page-break-before: auto; }
      h2 { page-break-after: avoid; }
      figure, table { page-break-inside: avoid; }
      details { border: none; }
      details > summary { display: none; }
      details > .details-body { display: block !important; }
      .figure-grid { grid-template-columns: 1fr; }
      a { color: var(--ink); text-decoration: none; }
    }

    @media (max-width: 700px) {
      body { padding: 1em; }
      .figure-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <header class="title-block">
    <h1>MoonAI Profiler Analysis Report</h1>
    <p class="subtitle">MoonAI Project &mdash; TED University</p>
    <p class="date">{{ report_name }} &middot; generated {{ generated_at }}</p>
  </header>
  <hr class="title-rule">

  <section class="abstract">
    <h2>Abstract</h2>
    <p>
      This report presents profiling data from {{ run_count }} headless simulation
      run{{ 's' if run_count != 1 else '' }}.
      To reduce noise from cold-start and late-run variance, the first and last
      25% of generations are discarded (IQR trimming); all reported averages,
      charts, and event tables use only the middle 50% of generations.
      {{ skipped_count }} profile{{ 's' if skipped_count != 1 else '' }} could not be analysed and
      {{ 'are' if skipped_count != 1 else 'is' }} listed in Excluded Profiles.
      Source directory: <code>{{ input_dir }}</code>.
    </p>
  </section>

  <nav class="toc">
    <strong>Contents</strong>
    <ul>
      <li><a href="#summary">Run Summary</a></li>
      <li><a href="#comparisons">Cross-Run Comparisons</a></li>
      <li><a href="#runs">Profile Details</a>
        <ul>
          {% for run in run_sections %}
          <li><a href="#run-{{ loop.index }}">{{ run.label }}</a></li>
          {% endfor %}
        </ul>
      </li>
      <li><a href="#skipped">Excluded Profiles</a></li>
    </ul>
  </nav>

  <section id="summary">
    <h2>Run Summary</h2>
    <table>
      <caption>Per-run overview of generation timing and dominant hotspots (IQR-trimmed).</caption>
      <thead>
        <tr>
          <th>Run</th>
          <th>Total Gens</th>
          <th>Trimmed Gens</th>
          <th>Avg Gen (ms)</th>
          <th>Top Event</th>
          <th>Top Event Avg (ms/active gen)</th>
          <th>Path</th>
        </tr>
      </thead>
      <tbody>
        {% for row in summary_rows %}
        <tr>
          <td>{{ row.label }}</td>
          <td>{{ row.total_generations }}</td>
          <td>{{ row.trimmed_generations }}</td>
          <td>{{ row.avg_generation_ms }}</td>
          <td>{{ row.top_event }} ({{ row.top_event_nonzero_generation_count }} active)</td>
          <td>{{ row.top_event_avg_ms }}</td>
          <td><code>{{ row.path }}</code></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <section id="comparisons">
    <h2>Cross-Run Comparisons</h2>
    <div class="figure-grid">
      {% for chart in comparison_charts %}
      <figure>
        <img src="{{ chart.image_uri }}" alt="{{ chart.title }} chart">
        <figcaption>{{ chart.title }}. {{ chart.caption }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </section>

  <section id="runs">
    <h2>Profile Details</h2>
    {% for run in run_sections %}
    <details id="run-{{ loop.index }}" {% if loop.first %}open{% endif %}>
      <summary>{{ run.label }}</summary>
      <div class="details-body">
        <p class="run-meta">
          <em>Run dir:</em> {{ run.name }} &ensp;|&ensp;
          <em>Mode:</em> {{ run.mode }} &ensp;|&ensp;
          <em>{{ run.trim_note }}</em> &ensp;|&ensp;
          <em>Avg generation:</em> {{ run.avg_generation_ms }} ms
        </p>
        <p class="run-meta">
          <em>Top event:</em> {{ run.top_event_name }} ({{ run.top_event_avg_ms }} ms/active gen,
          {{ run.top_event_nonzero_generation_count }} active generations,
          {{ run.top_event_total_ms }} ms total)
        </p>

        {% if run.summary_meta.path_count_note %}
        <div class="note">{{ run.summary_meta.path_count_note }}</div>
        {% endif %}

        {% if run.run_notes %}
        <h3>Profiler Notes</h3>
        <table>
          <tbody>
            {% for note in run.run_notes %}
            <tr><td>{{ note }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
        {% endif %}

        <div class="figure-grid">
          {% for chart in run.charts %}
          <figure>
            <img src="{{ chart.image_uri }}" alt="{{ chart.title }} chart">
            <figcaption>{{ chart.title }}. {{ chart.caption }}</figcaption>
          </figure>
          {% endfor %}
        </div>

        <h3>Run Metadata</h3>
        <table>
          <tbody>
            {% for key, value in run.run_meta.items() %}
            <tr>
              <th>{{ key }}</th>
              <td>{{ value }}</td>
            </tr>
            {% endfor %}
            <tr>
              <th>profile_path</th>
              <td><code>{{ run.path }}</code></td>
            </tr>
          </tbody>
        </table>

        <h3>Summary Events</h3>
        <table>
          <caption>All profiled events sorted by total time (IQR-trimmed generations).</caption>
          <thead>
            <tr>
              <th>Event</th>
              <th>Total (ms)</th>
              <th>Avg / Generation</th>
              <th>Nonzero Generations</th>
              <th>Avg / Nonzero Generation</th>
            </tr>
          </thead>
          <tbody>
            {% for row in run.summary_events %}
            <tr>
              <td>{{ row.name }}</td>
              <td>{{ row.total_ms }}</td>
              <td>{{ row.avg_ms_per_generation }}</td>
              <td>{{ row.nonzero_generation_count }}</td>
              <td>{{ row.avg_ms_per_nonzero_generation }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>

        <h3>Summary Counters</h3>
        <table>
          <caption>All profiled counters sorted by total value (IQR-trimmed generations).</caption>
          <thead>
            <tr>
              <th>Counter</th>
              <th>Total</th>
              <th>Avg / Generation</th>
              <th>Nonzero Generations</th>
              <th>Avg / Nonzero Generation</th>
            </tr>
          </thead>
          <tbody>
            {% for row in run.summary_counters %}
            <tr>
              <td>{{ row.name }}</td>
              <td>{{ row.total }}</td>
              <td>{{ row.avg_per_generation }}</td>
              <td>{{ row.nonzero_generation_count }}</td>
              <td>{{ row.avg_per_nonzero_generation }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </details>
    {% endfor %}
  </section>

  <section id="skipped">
    <h2>Excluded Profiles</h2>
    {% if skipped_profiles %}
    <table>
      <caption>Profiles that could not be included in the analysis.</caption>
      <thead>
        <tr><th>Name</th><th>Reason</th></tr>
      </thead>
      <tbody>
        {% for skipped in skipped_profiles %}
        <tr>
          <td>{{ skipped.name }}</td>
          <td>{{ skipped.reason }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <div class="empty">No profiles were skipped.</div>
    {% endif %}
  </section>

</body>
</html>
