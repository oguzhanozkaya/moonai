<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MoonAI Analysis Report</title>
  <style>
    :root {
      --bg: #f6f1e8;
      --paper: #fffdf8;
      --ink: #1f2933;
      --muted: #52606d;
      --line: #d9cbb8;
      --accent: #8c3f2f;
      --accent-soft: #f1dfd4;
      --shadow: 0 20px 45px rgba(65, 45, 20, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      background: linear-gradient(180deg, #efe7d9 0%, var(--bg) 100%);
      color: var(--ink);
      line-height: 1.5;
    }
    .page {
      width: min(1240px, calc(100vw - 32px));
      margin: 24px auto 48px;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 24px;
      align-items: start;
    }
    .sidebar {
      position: sticky;
      top: 20px;
      padding: 20px;
      background: rgba(255, 253, 248, 0.88);
      border: 1px solid rgba(217, 203, 184, 0.9);
      border-radius: 18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }
    .content {
      display: grid;
      gap: 20px;
    }
    .panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 24px;
    }
    h1, h2, h3 { margin: 0 0 12px; line-height: 1.15; }
    h1 { font-size: 2.2rem; }
    h2 { font-size: 1.45rem; color: var(--accent); }
    h3 { font-size: 1.05rem; }
    p, li, td, th, summary { color: var(--ink); }
    .muted { color: var(--muted); }
    .hero {
      display: grid;
      gap: 16px;
      background:
        radial-gradient(circle at top right, rgba(140, 63, 47, 0.10), transparent 34%),
        linear-gradient(135deg, rgba(255,255,255,0.7), rgba(241,223,212,0.6));
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
    }
    .stat {
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(140, 63, 47, 0.06);
      border: 1px solid rgba(140, 63, 47, 0.12);
    }
    .stat strong { display: block; font-size: 1.35rem; }
    .toc ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
    .toc a { color: var(--accent); text-decoration: none; }
    .toc a:hover { text-decoration: underline; }
    table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: 14px;
      background: white;
    }
    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid #eadfce;
      text-align: left;
      vertical-align: top;
      font-size: 0.95rem;
    }
    th {
      background: #f7efe5;
      color: var(--accent);
      position: sticky;
      top: 0;
    }
    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 18px;
    }
    figure {
      margin: 0;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #fff;
    }
    img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 12px;
      background: #fff;
    }
    figcaption {
      margin-top: 10px;
      color: var(--muted);
      font-size: 0.92rem;
    }
    details {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #fffcf8;
      overflow: hidden;
    }
    details + details { margin-top: 14px; }
    summary {
      cursor: pointer;
      list-style: none;
      padding: 18px 20px;
      background: linear-gradient(90deg, rgba(140,63,47,0.08), rgba(140,63,47,0.02));
      font-weight: 700;
    }
    summary::-webkit-details-marker { display: none; }
    .details-body { padding: 18px; display: grid; gap: 18px; }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 0.92rem;
      color: var(--muted);
    }
    .pill {
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--accent-soft);
      border: 1px solid rgba(140, 63, 47, 0.16);
    }
    .empty {
      padding: 16px;
      border-radius: 16px;
      background: #faf5ee;
      color: var(--muted);
      border: 1px dashed var(--line);
    }
    @media (max-width: 980px) {
      .page { grid-template-columns: 1fr; }
      .sidebar { position: static; }
    }
  </style>
</head>
<body>
  <div class="page">
    <aside class="sidebar">
      <div class="toc">
        <h3>Contents</h3>
        <ul>
          <li><a href="#overview">Overview</a></li>
          <li><a href="#summary">Summary</a></li>
          <li><a href="#comparisons">Comparisons</a></li>
          <li><a href="#conditions">Conditions</a></li>
          <li><a href="#skipped">Skipped Runs</a></li>
        </ul>
      </div>
    </aside>

    <main class="content">
      <section class="panel hero" id="overview">
        <div>
          <h1>MoonAI Analysis Report</h1>
          <p class="muted">{{ report_name }} · generated {{ generated_at }}</p>
        </div>
        <div class="stats">
          <div class="stat"><span class="muted">Input directory</span><strong>{{ input_dir }}</strong></div>
          <div class="stat"><span class="muted">Analysed runs</span><strong>{{ run_count }}</strong></div>
          <div class="stat"><span class="muted">Conditions</span><strong>{{ condition_count }}</strong></div>
          <div class="stat"><span class="muted">Skipped runs</span><strong>{{ skipped_count }}</strong></div>
        </div>
      </section>

      <section class="panel" id="summary">
        <h2>Summary</h2>
        <p class="muted">Grouped metrics at generation {{ summary_generation }} (mean +/- std across runs).</p>
        <table>
          <thead>
            <tr>
              {% for header in summary_headers %}
              <th>{{ header.replace('_', ' ').title() }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in summary_rows %}
            <tr>
              <td>{{ row.condition }}</td>
              <td>{{ row.run_count }}</td>
              {% for metric_name, metric_value in row.metrics.items() %}
              <td>{{ metric_value }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section class="panel" id="comparisons">
        <h2>Cross-Condition Comparisons</h2>
        <div class="chart-grid">
          {% for chart in comparison_charts %}
          <figure>
            <h3>{{ chart.title }}</h3>
            <img src="{{ chart.image_uri }}" alt="{{ chart.title }} chart">
            <figcaption>{{ chart.caption }}</figcaption>
          </figure>
          {% endfor %}
        </div>
      </section>

      <section class="panel" id="conditions">
        <h2>Conditions</h2>
        {% for condition in condition_sections %}
        <details {% if loop.first %}open{% endif %}>
          <summary>{{ condition.label }}</summary>
          <div class="details-body">
            <div class="meta">
              <span class="pill">Runs: {{ condition.run_count }}</span>
              <span class="pill">Representative run: {{ condition.representative_run }}</span>
              <span class="pill">Final generation: {{ condition.final_generation }}</span>
            </div>
            <div class="chart-grid">
              {% for chart in condition.charts %}
              <figure>
                <h3>{{ chart.title }}</h3>
                <img src="{{ chart.image_uri }}" alt="{{ condition.label }} {{ chart.title }} chart">
                <figcaption>{{ chart.caption }}</figcaption>
              </figure>
              {% endfor %}
              {% if condition.genome_chart %}
              <figure>
                <h3>{{ condition.genome_chart.title }}</h3>
                <img src="{{ condition.genome_chart.image_uri }}" alt="{{ condition.label }} genome chart">
                <figcaption>{{ condition.genome_chart.caption }}</figcaption>
              </figure>
              {% endif %}
            </div>
          </div>
        </details>
        {% endfor %}
      </section>

      <section class="panel" id="skipped">
        <h2>Skipped Runs</h2>
        {% if skipped_runs %}
        <table>
          <thead>
            <tr>
              <th>Run</th>
              <th>Reason</th>
            </tr>
          </thead>
          <tbody>
            {% for skipped in skipped_runs %}
            <tr>
              <td>{{ skipped.name }}</td>
              <td>{{ skipped.reason }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <div class="empty">No runs were skipped.</div>
        {% endif %}
      </section>
    </main>
  </div>
</body>
</html>
