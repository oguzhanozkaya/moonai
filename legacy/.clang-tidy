#
# MoonAI Clang-Tidy Configuration
# https://clang.llvm.org/extra/clang-tidy/
#
# Usage:
#   clang-tidy -p <build-dir> <file>
#   or run via: just lint
#

---
Checks: >
  # Dead code detection (primary focus)
  clang-analyzer-deadcode.DeadStores,
  misc-unused-alias-decls,
  misc-unused-parameters,
  misc-unused-using-decls,
  bugprone-unused-local-non-trivial-variable,
  bugprone-unused-raii,
  bugprone-unused-return-value,
  readability-delete-null-pointer,
  readability-redundant-*,
  
  # Core bug detection
  clang-analyzer-core.*,
  bugprone-*,
  
  # Modernization (C++17 best practices)
  modernize-*,
  
  # Code quality
  cppcoreguidelines-*,
  
  # Performance
  performance-*,
  
  # Readability
  readability-*,
  
  # Disable noisy/undesirable checks
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-type-vararg,
  -readability-named-parameter,
  -readability-braces-around-statements,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  -readability-magic-numbers,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -cppcoreguidelines-narrowing-conversions,
  -cppcoreguidelines-special-member-functions,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -modernize-use-default-member-init,
  -performance-enum-size

WarningsAsErrors: ''

HeaderFilterRegex: 'src/.*'

# System headers to ignore
SystemHeaders: false

FormatStyle: file

CheckOptions:
  # Dead code specific options
  - key:   readability-redundant-member-init.IgnoreBaseInCopyConstructors
    value: '1'
  
  # Unused parameters
  - key:   misc-unused-parameters.StrictMode
    value: '1'
  
  # Modernization preferences
  - key:   modernize-loop-convert.MinConfidence
    value: reasonable
  
  # Performance
  - key:   performance-for-range-copy.WarnOnAllAutoCopies
    value: '1'
  
  # Readability
  - key:   readability-identifier-naming.NamespaceCase
    value: lower_case
  - key:   readability-identifier-naming.ClassCase
    value: PascalCase
  - key:   readability-identifier-naming.StructCase
    value: PascalCase
  - key:   readability-identifier-naming.FunctionCase
    value: camelBack
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  - key:   readability-identifier-naming.MemberSuffix
    value: '_'
  - key:   readability-identifier-naming.EnumCase
    value: PascalCase
  - key:   readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  
  # CUDA-specific (if present)
  - key:   cppcoreguidelines-pro-type-vararg.HungarianPrefix
    value: ''


